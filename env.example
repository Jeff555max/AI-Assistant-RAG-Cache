# Конфигурация для RAG-ассистента
# Скопируйте этот файл в .env и заполните значения

# ============================================
# ОБЯЗАТЕЛЬНЫЕ НАСТРОЙКИ
# ============================================

# API ключ OpenAI (обязательно!)
# Используется как для генерации ответов, так и для создания эмбеддингов
# Получите ключ на https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# TELEGRAM БОТ (для bot_main.py)
# ============================================

# Токен Telegram бота (получить у @BotFather)
# Обязательно для запуска Telegram бота
# 1. Найдите @BotFather в Telegram
# 2. Отправьте команду /newbot
# 3. Следуйте инструкциям
# 4. Скопируйте полученный токен сюда
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ
# ============================================

# Модель для генерации ответов (по умолчанию: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Температура для генерации (0.0 - детерминированный, 1.0 - креативный)
TEMPERATURE=0.7

# Модель для создания эмбеддингов (по умолчанию: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small
# Альтернативы: text-embedding-3-large, text-embedding-ada-002

# Директория для ChromaDB (по умолчанию: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# Имя коллекции в ChromaDB (по умолчанию: rag_documents)
COLLECTION_NAME=rag_documents

# Файл кеша (по умолчанию: cache.json)
CACHE_FILE=cache.json

# База данных логов (по умолчанию: logs.db)
LOGS_DB_PATH=logs.db

